{
  "name": "aoles-gl-vue",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "A web video editor utilizing Vue.js and WebGL/OpenGL, delivering ultimate high performance.",
  "keywords": [
    "video-editor",
    "webgl",
    "vue3",
    "canvas",
    "ai",
    "video-processing"
  ],
  "homepage": "https://github.com/laoleshisui/aoles-gl-vue-open",
  "repository": {
    "type": "git",
    "url": "https://github.com/laoleshisui/aoles-gl-vue-open.git"
  },
  "bugs": {
    "url": "https://github.com/laoleshisui/aoles-gl-vue-open/issues"
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "style": "dist/style.css",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist/index.es.js",
    "dist/index.cjs.js",
    "dist/index.d.ts",
    "dist/style.css",
    "dist/wasm",
    "dist/glsl",
    "dist/index.es.js.map",
    "dist/index.cjs.js.map"
  ],
  "scripts": {
    "build": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "lint-fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.0.0",
    "pinia": "^2.0.0",
    "element-plus": "^2.0.0",
    "@element-plus/icons-vue": "^2.0.0",
    "@vueuse/core": "^10.0.0",
    "vue-i18n": "^9.0.0",
    "axios": "^1.0.0",
    "lodash-es": "^4.17.0",
    "@webav/av-cliper": "^0.9.0",
    "vue3-moveable": "^0.18.0",
    "wavesurfer.js": "^7.0.0",
    "zod": "^4.0.0",
    "@ckpack/vue-color": "^1.4.0",
    "@ctrl/tinycolor": "^4.0.0",
    "@floating-ui/vue": "^1.0.0",
    "opfs-tools": "^0.4.0",
    "spark-md5": "^3.0.0",
    "srt-parser-2": "^1.2.0",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue-element-plus-x": "^1.3.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.1.4",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.2",
    "@tailwindcss/typography": "^0.5.9",
    "@types/jsdom": "^20.0.1",
    "@types/lodash-es": "^4.17.6",
    "@types/node": "^18.11.18",
    "@types/spark-md5": "^3.0.4",
    "@types/webpack-env": "^1.18.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-typescript": "^11.0.0",
    "@vue/test-utils": "^2.2.6",
    "@vue/tsconfig": "^0.1.3",
    "autoprefixer": "^10.4.13",
    "cssnano": "^5.1.14",
    "eslint": "^8.22.0",
    "eslint-plugin-vue": "^9.3.0",
    "jsdom": "^20.0.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "postcss-import": "^15.1.0",
    "postcss-nesting": "^11.1.0",
    "sass": "^1.75.0",
    "tailwindcss": "^3.2.4",
    "typescript": "~4.7.4",
    "vite": "^4.0.0",
    "vitest": "^0.25.8",
    "vue-tsc": "^1.0.12"
  }
}
